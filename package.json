{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm start --prefix apps/api\"",
		"build": "npm run build -w web",
		"start": "concurrently --kill-others --raw",
		"lint": "npm run lint --prefix apps/web"
	},
	"devDependencies": {
		"concurrently": "^9.1.2"
	},
	"workspaces": [
		"apps/*"
	],
	"dependencies": {
		"@vercel/analytics": "^2.0.1"
	}
}
